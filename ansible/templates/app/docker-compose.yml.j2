services:
  app:
    image: {{ app_image }}:{{ app_image_tag }}
    container_name: {{ project_name }}
    restart: unless-stopped
    #deploy:
    #  resources:
    #    limits:
    #      cpus: '0.5'
    env_file:
      - .env
    environment:
      # Internal system agent (host metrics + operations). Empty secret => app treats
      # the agent as unconfigured and only shows in-app metrics.
      SYSTEM_AGENT_URL: "http://{{ project_name }}_agent:8080"
      SYSTEM_AGENT_SECRET: "{{ agent_secret | default('') }}"
    volumes:
      - ./media:/app/public/media
      - next_cache:/app/.next/cache/images
    networks:
      proxy: {}
      internal: {}
      postgres: {}
      # Reach the internal system agent (host metrics + operations) by DNS.
      agentnet: {}
      ip6net:
        ipv6_address: {{ ipv6_address }}
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.routers.{{ project_name }}.rule=Host(`{{ domain }}`)"
      - "traefik.http.routers.{{ project_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ project_name }}.tls.certresolver=cloudflare"
      - "traefik.http.services.{{ project_name }}.loadbalancer.server.port=3000"

volumes:
  next_cache:

networks:
  postgres:
    external: true
  proxy:
    external: true
  agentnet:
    external: true
  internal:
    driver: bridge
  ip6net:
    enable_ipv6: true
    ipam:
      config:
        - subnet: {{ ipv6_subnet }}