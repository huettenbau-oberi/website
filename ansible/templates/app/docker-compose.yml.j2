services:
  app:
    image: {{ app_image }}:{{ app_image_tag }}
    container_name: {{ project_name }}
    restart: unless-stopped
    #deploy:
    #  resources:
    #    limits:
    #      cpus: '0.5'
    env_file:
      - .env
    volumes:
      - ./media:/app/public/media
      - next_cache:/app/.next/cache/images
    networks:
      - proxy
      - internal
      - postgres
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.routers.{{ project_name }}.rule=Host(`{{ domain }}`)"
      - "traefik.http.routers.{{ project_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ project_name }}.tls.certresolver=cloudflare"
      - "traefik.http.services.{{ project_name }}.loadbalancer.server.port=3000"

volumes:
  next_cache:

networks:
  postgres:
    external: true
  proxy:
    external: true
  internal:
    driver: bridge
